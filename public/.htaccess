<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Si el archivo o directorio existe, sírvelo directamente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Si no, redirige todo a index.php (Enrutador MVC)
    RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>

# Deshabilitar listado de directorios por seguridad
Options -Indexes

# Proteger archivos ocultos
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>