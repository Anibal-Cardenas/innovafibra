{
    "name": "sistema-napa",
    "description": "Sistema de Gestión de Producción para Taller de Napa",
    "version": "1.0.0",
    "type": "project",
    "keywords": ["mrp", "erp", "producción", "inventario", "php"],
    "license": "proprietary",
    "require": {
        "php": ">=7.4.0",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\Controllers\\": "src/controllers/",
            "App\\Models\\": "src/models/",
            "App\\Services\\": "src/services/"
        },
        "files": [
            "src/helpers/functions.php",
            "src/helpers/session.php",
            "src/helpers/validation.php"
        ]
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
